APP_NAME=SPAMPK
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Kuala_Lumpur
APP_URL=http://127.0.0.1:8000
APP_LOCALE=ms

# Pangkalan data pada cakera setempat (HDD/SSD PC)
DB_CONNECTION=sqlite
# DB_DATABASE dibiar kosong = guna database/database.sqlite

# Luar talian sepenuhnya - tiada perkhidmatan luar
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
MAIL_MAILER=log
LOG_CHANNEL=single
